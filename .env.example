# ─────────────────────────────────────────────
# Nango Frontend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── better-auth ─────────────────────────────────────────────────────────────────
# Secret key used to encrypt and sign session cookies and security tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters. NEVER commit the real value.
# NOTE: This is separate from CREDENTIAL_ENCRYPTION_KEYRING for security isolation.
BETTER_AUTH_SECRET=change-me-use-a-long-random-secret-32-chars-min

# ── Credential encryption (keyring) ─────────────────────────────────────────────
# AES-256-GCM keyring used to encrypt all credentials stored in DB.
# Ciphertext format: v1:<keyId>:<iv>:<authTag>:<ct>
# Protects: Third-party API keys, tokens, and secrets (backend platforms, Langfuse, etc.).
#
# CREDENTIAL_ENCRYPTION_KEYRING
#   Comma-separated list of `<keyId>=<64-hex>` entries. Every key listed here
#   can decrypt rows that reference it.
#   Generate a key with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   keyId must match /^[A-Za-z0-9_-]{1,32}$/.
#
# CREDENTIAL_ENCRYPTION_ACTIVE_KEY_ID
#   keyId from the keyring used to encrypt NEW writes. Must reference an
#   entry in CREDENTIAL_ENCRYPTION_KEYRING.
#
# Rotation procedure: see docs/key-rotation.md.
CREDENTIAL_ENCRYPTION_ACTIVE_KEY_ID=k1
CREDENTIAL_ENCRYPTION_KEYRING=k1=<replace-with-64-hex-generated-as-shown-above>


# Host-side port (optional). 
# APP_PORT=9300

# Public URL the browser uses to reach Nango — used by better-auth for cookies,
# redirects, and OAuth callbacks. Set explicitly because better-auth only
# auto-derives baseURL when a full request header is available; server-side
# calls (server components, server-side fetches) emit
#   [Better Auth] Base URL could not be determined.
# at startup if unset. In docker, compose substitutes the same default. Override
# only behind a reverse proxy / custom domain (e.g. https://nango.example.com).
BETTER_AUTH_URL=http://localhost:9300

# Set to "1" to disable HTTPS cookies in local dev (no SSL)
NO_HTTPS=1


# ── Observability: structured logs (optional) ──────────────────────────────────────
#
# NANGO_LOG_LEVEL     pino level (debug | info | warn | error | silent).
#                     Default: "info". Use "debug" temporarily when triaging.
# NANGO_LOG_PRETTY    "true" | "false". Default: "false" (JSON-only — works
#                     with Docker / Loki / Datadog / CloudWatch log shippers).
#                     Set to "true" in local dev for human-readable colours.
NANGO_LOG_ENABLED=true
NANGO_LOG_LEVEL=warn
# NANGO_LOG_PRETTY=true

# Silence the "[CopilotKit Runtime] anonymous telemetry enabled" startup
# warning. See https://docs.copilotkit.ai/telemetry.
COPILOTKIT_TELEMETRY_DISABLED=true
