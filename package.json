{
  "name": "nango",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev -p 9300",
    "predev": "pnpm build:skills && pnpm sandbox:image",
    "build:skills": "tsx scripts/build-skills.ts",
    "sandbox:deps": "tsx scripts/collect-skill-deps.ts",
    "sandbox:check": "tsx scripts/collect-skill-deps.ts --check",
    "sandbox:build": "pnpm sandbox:deps && pnpm sandbox:image",
    "sandbox:image": "tsx scripts/ensure-sandbox-image.ts",
    "prebuild": "pnpm build:skills",
    "build": "next build",
    "prestart": "pnpm build:skills && pnpm sandbox:image",
    "start": "next start -p 9300",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env docker/migrate.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "docker:db": "docker compose up -d nango-db",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f nango-app",
    "prepare": "husky",
    "check": "pnpm lint && pnpm check-types && pnpm test"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@ai-sdk/xai": "^3.0.90",
    "@base-ui/react": "^1.4.1",
    "@copilotkit/react-core": "^1.59.2",
    "@copilotkit/react-ui": "^1.59.2",
    "@copilotkit/runtime": "^1.59.2",
    "@dagrejs/dagre": "^3.0.0",
    "@duckdb/node-api": "1.5.2-r.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@rjsf/core": "^6.5.2",
    "@rjsf/shadcn": "^6.5.2",
    "@rjsf/utils": "^6.5.2",
    "@rjsf/validator-ajv8": "^6.5.2",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.182",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.0.0",
    "emoji-picker-react": "^4.19.1",
    "jszip": "^3.10.1",
    "langfuse": "^3.38.20",
    "lru-cache": "^11.3.6",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-sql-parser": "^5.4.0",
    "node-ssh": "^13.2.1",
    "ollama-ai-provider-v2": "^3.5.1",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-resizable-panels": "^4.11.1",
    "rehype-highlight": "^7.0.2",
    "rxjs": "^7.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.8.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vertica-nodejs": "^1.1.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
