# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown exception (allow trailing whitespace for line breaks)
[*.md]
trim_trailing_whitespace = false

# Nango: Python Skills follow the community standard of 4 spaces
[*.py]
indent_size = 4