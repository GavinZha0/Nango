# Set default behavior
* text=auto eol=lf

# Frontend / Node core files
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Nango-specific files (Skills sandbox scripts and DB migrations)
*.py text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.txt text eol=lf

# Truly binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary