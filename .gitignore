# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
tests/e2e/.auth/

# next.js
/.next/
/out/

# production
/build
/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.idea/

# skills/ is now an authoring view only (consumed by `pnpm build:skills`
# at build time, materialised into dist/builtin-skills.json). Every
# subdirectory with a valid SKILL.md is a builtin candidate; track them
# all in git.

# screenshots / reference images placed at the project root
# during design iteration — not source
/Screenshot-*.png
/Screenshot-*.jpg
/xyflow.png

# runtime caches under the project root:
#   .cache/datasource/parquet/<name>/        Parquet snapshots written by
#                                            `extract_dataset_by_sql`
#   .cache/datasource/parquet/<name>.json    Sidecar metadata
#   .cache/datasource/.write-slots/          Per-call staging dirs
# See `src/lib/data-sources/cache-root.ts` and `docs/sandbox.md` §3.
/.cache/
