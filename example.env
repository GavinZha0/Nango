# ─────────────────────────────────────────────
# Nango Frontend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# better-auth
# Secret key used to encrypt and sign session cookies and security tokens.
# Protects: User authentication sessions, CSRF tokens, and auth-related data.
# Scope: Browser ↔ Server (cookies), not used for database encryption.
# Impact if leaked: Attackers can forge sessions and hijack user logins.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters. NEVER commit the real value.
# NOTE: This is separate from CREDENTIAL_ENCRYPTION_KEYRING for security isolation.
BETTER_AUTH_SECRET=change-me-use-a-long-random-secret-32-chars-min
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to "1" to disable HTTPS cookies in local dev (no SSL)
NO_HTTPS=1

# ── Credential encryption (keyring) ─────────────────────────────────────────────
# AES-256-GCM keyring used to encrypt all credentials stored in DB.
# Ciphertext format: v1:<keyId>:<iv>:<authTag>:<ct>
# Protects: Third-party API keys, tokens, and secrets (backend platforms, Langfuse, etc.).
# Scope: Database persistence (credential table), NOT session cookies.
# Impact if leaked: Attackers can decrypt all stored third-party credentials.
#
# CREDENTIAL_ENCRYPTION_KEYRING
#   Comma-separated list of `<keyId>=<64-hex>` entries. Every key listed here
#   can decrypt rows that reference it; this is what makes zero-downtime
#   rotation possible (old + new keys coexist during the transition).
#   Generate a key with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   keyId must match /^[A-Za-z0-9_-]{1,32}$/.
#
# CREDENTIAL_ENCRYPTION_ACTIVE_KEY_ID
#   keyId from the keyring used to encrypt NEW writes. Must reference an
#   entry in CREDENTIAL_ENCRYPTION_KEYRING.
#
# Rotation procedure: see docs/key-rotation.md.
CREDENTIAL_ENCRYPTION_ACTIVE_KEY_ID=k1
CREDENTIAL_ENCRYPTION_KEYRING=k1=<replace-with-64-hex-generated-as-shown-above>
# CREDENTIAL_ENCRYPTION_KEYRING=k1=c60f15a2dd1bdecd92bca72728ec8104c0570832e9d8827592bfa865ba35fc5a

# ── Observability: structured logs (pino) ──────────────────────────────────────
# Phase 1 of the observability layer (see docs/observability.md). Independent of
# any external SaaS — covers proxy dispatch, credential lookup, and BuiltIn
# agent runtime. Sensitive fields (tokens, secrets, Authorization headers) are
# automatically redacted.
#
# NANGO_LOG_ENABLED   "true" (default) | "false"  — master kill switch.
#                     Set to "false" in environments where you want to silence
#                     all Nango logs without redeploying.
# NANGO_LOG_LEVEL     pino level (debug | info | warn | error | silent).
#                     Default: "info". Use "debug" temporarily when triaging.
# NANGO_LOG_PRETTY    "true" | "false". Default: "true" outside production,
#                     "false" in production (JSON-only — required for log
#                     shippers like Loki, Datadog, CloudWatch).
NANGO_LOG_ENABLED=true
NANGO_LOG_LEVEL=info
NANGO_LOG_PRETTY=true
NANGO_RUNNER_BACKEND=db